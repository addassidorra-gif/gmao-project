SECRET_KEY=change-this-secret-key
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,gmao-project.onrender.com
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://gmao-project.onrender.com
ADMIN_EMAIL=admin@enib.tn
ADMIN_PASSWORD=change-this-admin-password
DJANGO_SUPERUSER_FULL_NAME=Administrateur ENIB

# Supabase / PostgreSQL
# Supabase Transaction Pooler example:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
# Direct database example:
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# Leave empty only for local SQLite development.
DATABASE_URL=

# Demo data is never loaded automatically. Use:
# python manage.py seed_demo_data
# On PostgreSQL/Supabase this command requires --allow-production.
